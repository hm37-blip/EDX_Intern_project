import pandas as pd
import os

folder_path = 'C:\\Users\\Manzh\\OneDrive\\桌面\\edx'
input_file = os.path.join(folder_path, 'Final_Sold_Data_Consolidated.csv')
output_file = os.path.join(folder_path, 'Logic_Cleaned_Sold_Data.csv')

df = pd.read_csv(input_file, low_memory=False, encoding='latin1')
initial_count = len(df)

#keep only residential
df = df[df['PropertyType'] == 'Residential'].copy()

#transfrom prices, living area, days on market to number
cols_to_fix = ['ClosePrice', 'LivingArea', 'OriginalListPrice', 'DaysOnMarket']
for col in cols_to_fix:
    df[col] = pd.to_numeric(df[col], errors='coerce')

#price and area must >0
df = df[(df['ClosePrice'] > 0) & (df['LivingArea'] > 0)]
#kick out extrmely low value
df = df[df['ClosePrice'] >= 50000]

#date change again
df['CloseDate'] = pd.to_datetime(df['CloseDate'], errors='coerce')
df['ListingContractDate'] = pd.to_datetime(df['ListingContractDate'], errors='coerce')
df = df[df['CloseDate'] >= df['ListingContractDate']]

#sold-listing-ratio must be reasonable
df['SoldToListRatio'] = df['ClosePrice'] / df['OriginalListPrice']
df = df[(df['SoldToListRatio'] >= 0.3) & (df['SoldToListRatio'] <= 2.0)]

df.to_csv(output_file, index=False, encoding='utf-8-sig')
