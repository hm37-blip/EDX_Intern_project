import pandas as pd
import os

folder_path = 'C:\\Users\\Manzh\\OneDrive\\桌面\\edx'
input_file = os.path.join(folder_path, 'Clean_Listing_Data_v1.csv)
output_file = os.path.join(folder_path, 'Clean_Listing_Data_v2.csv')
df = pd.read_csv(input_file, low_memory=False, encoding='latin1')

#filter out extremely low price
df['ClosePrice'] = pd.to_numeric(df['ClosePrice'], errors='coerce')
df = df[df['ClosePrice'] >= 50000]

# filter out extremely small house
df['LivingArea'] = pd.to_numeric(df['LivingArea'], errors='coerce')
df = df[df['LivingArea'] > 100]

#close date must be later than listing date
df['CloseDate'] = pd.to_datetime(df['CloseDate'], errors='coerce')
df['ListingContractDate'] = pd.to_datetime(df['ListingContractDate'], errors='coerce')
df = df[df['CloseDate'] >= df['ListingContractDate']]

#  deal price must be in a reseasonalible ratio to listing price
df['OriginalListPrice'] = pd.to_numeric(df['OriginalListPrice'], errors='coerce')
df['SoldToListRatio'] = df['ClosePrice'] / df['OriginalListPrice']
df = df[(df['SoldToListRatio'] >= 0.3) & (df['SoldToListRatio'] <= 2.0)]

df.to_csv(output_file, index=False, encoding='utf-8-sig')
