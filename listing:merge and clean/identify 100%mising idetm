def get_empty_columns(df, name):
    missing_series = df.isnull().mean()
    empty_cols = missing_series[missing_series == 1.0].index.tolist()
    
    print(f"\n--- {name} data set colum with 100% missing item ({len(empty_cols)}个) ---")
    print(empty_cols)
    return empty_cols

